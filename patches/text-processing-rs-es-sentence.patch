+
+    // ── normalize_sentence_with_lang (ITN) ──────────────────────────────
+
+    #[test]
+    fn test_itn_sentence_es_cardinal() {
+        assert_eq!(
+            normalize_sentence_with_lang("tengo veinticinco años", "es"),
+            "tengo 25 años"
+        );
+        assert_eq!(
+            normalize_sentence_with_lang(
+                "vivo en el piso doscientos cincuenta y uno",
+                "es"
+            ),
+            "vivo en el piso 251"
+        );
+    }
+
+    #[test]
+    fn test_itn_sentence_es_time_money_date() {
+        assert_eq!(
+            normalize_sentence_with_lang("el tren sale a las nueve y media", "es"),
+            "el tren sale a las 9:30"
+        );
+        assert_eq!(
+            normalize_sentence_with_lang("pagué cinco euros", "es"),
+            "pagué €5"
+        );
+        assert_eq!(
+            normalize_sentence_with_lang("nací el quince de marzo", "es"),
+            "nací el 15 de marzo"
+        );
+    }
+
+    #[test]
+    fn test_itn_sentence_es_passthrough() {
+        assert_eq!(normalize_sentence_with_lang("hola mundo", "es"), "hola mundo");
+        assert_eq!(normalize_sentence_with_lang("", "es"), "");
+    }
+
+    #[test]
+    fn test_itn_sentence_en_delegates() {
+        // "en" routes through the existing English sentence scanner.
+        assert_eq!(
+            normalize_sentence_with_lang("I have twenty one apples", "en"),
+            "I have 21 apples"
+        );
+        assert_eq!(
+            normalize_sentence_with_lang("I have twenty one apples", ""),
+            "I have 21 apples"
+        );
+    }
+
+    #[test]
+    fn test_itn_sentence_unknown_lang_falls_back() {
+        // Unrecognised codes fall back to normalize_with_lang, which
+        // itself defaults to English for unknown languages.
+        assert_eq!(
+            normalize_sentence_with_lang("two hundred", "xx"),
+            "200"
+        );
+    }
 }
